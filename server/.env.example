# MySQL — URL-encode special chars in password (@ → %40)
DATABASE_URL="mysql://root:your_password@localhost:3306/tokri"

PORT=5000
NODE_ENV=development

# Custom admin URL path (not /admin — harder to guess)
ADMIN_PATH=/tokri-backoffice

# Public app URL (for password reset links)
APP_URL=http://localhost:5000

# Admin panel login (change in production)
ADMIN_EMAIL=admin@tokriii.com
ADMIN_PASSWORD=admin123

# Storefront URL (for CORS)
CLIENT_URL=http://localhost:5173

# Session secret (generate a long random string for production)
SESSION_SECRET=change-me-to-a-long-random-string

# Email (for password reset). Leave SMTP_HOST empty to log emails to console in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Tokriii <noreply@tokriii.com>

# Razorpay (Phase 4)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio (Phase 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
