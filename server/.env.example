# MySQL — URL-encode special chars in password (@ → %40)
DATABASE_URL="mysql://root:your_password@localhost:3306/tokri"

# Backend process port (on API server)
PORT=5222
NODE_ENV=production

# Custom admin URL path
ADMIN_PATH=/tokri-backoffice

# Public storefront + admin browser URL (www)
APP_URL=https://www.tokriii.com

# Storefront origin for CORS (usually same as APP_URL)
CLIENT_URL=https://www.tokriii.com

# Public API + uploads host (api subdomain)
API_URL=https://server.tokriii.com

# Optional extra CORS origins, comma-separated
# CORS_ORIGINS=https://www.tokriii.com,https://tokriii.com

# Set true when running behind Nginx/PM2 on production
TRUST_PROXY=true

# Admin panel login (change in production)
ADMIN_EMAIL=admin@tokriii.com
ADMIN_PASSWORD=admin123

# Session secret (generate a long random string for production)
SESSION_SECRET=change-me-to-a-long-random-string

# Email (for password reset). Leave SMTP_HOST empty to log emails to console in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Tokriii <noreply@tokriii.com>

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# --- Local development example ---
# PORT=5223
# NODE_ENV=development
# APP_URL=http://localhost:5222
# CLIENT_URL=http://localhost:5222
# API_URL=http://localhost:5223
# TRUST_PROXY=false
